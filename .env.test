# Valores DUMMY só para a suíte de testes (Vite carrega .env.test em modo test).
# Os testes mockam o supabase / validam estados de loading — o client nunca conecta de verdade.
# NÃO são segredos; servem só para `supabase.ts` construir o client sem lançar no import.
VITE_SUPABASE_URL=https://test.supabase.co
VITE_SUPABASE_ANON_KEY=test-anon-key-not-a-secret
